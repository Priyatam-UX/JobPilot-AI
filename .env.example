# ==============================================================================
# AI Job Copilot - Environment Configuration Template
# ==============================================================================

# System Setup
PROJECT_NAME="AI Job Copilot"
API_V1_STR="/api/v1"

# Database Configuration (Neon PostgreSQL / Local pg16 with pgvector)
# Local Dev Default: postgresql://postgres:postgrespassword@localhost:5432/job_copilot
DATABASE_URL="postgresql+psycopg://postgres:postgrespassword@localhost:5432/job_copilot"

# Cache & Celery broker (Upstash Redis / Local Redis alpine)
# Local Dev Default: redis://localhost:6379/0
REDIS_URL="redis://localhost:6379/0"

# AI Key Configurations
OPENAI_API_KEY="sk-proj-your-openai-api-key-here"

# Security (JWT Session configs)
JWT_SECRET="generate-a-secure-random-key-in-production-use-openssl-rand-hex-32"
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 1 week
REFRESH_TOKEN_EXPIRE_MINUTES=43200 # 30 days

# CORS Allowed origins (comma-separated)
CORS_ORIGINS='["http://localhost:5173", "http://127.0.0.1:5173", "https://jobspilotai.space", "https://www.jobspilotai.space"]'

# OAuth Credentials
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GITHUB_CLIENT_ID="your-github-oauth-client-id"
GITHUB_CLIENT_SECRET="your-github-oauth-client-secret"

# Storage Configurations (AWS S3)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret"
AWS_STORAGE_BUCKET_NAME="job-copilot-resumes"
USE_S3=false
